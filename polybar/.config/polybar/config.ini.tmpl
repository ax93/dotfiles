[bar/mybar]
width = 100%
margin-top = 4
margin-bottom = 0
offset-x = 0
offset-y = 5px
height = 18pt
radius = 6
override_redirect = false
pseudo-transparency = false

border-size = 3
border-top-size = 15
border-color = #00000000

background = #00000000
foreground = ${sem_fg}

line-size = 3pt
line-color = ${sem_accent}
padding-left = 1
padding-right = 1
module-margin = 0

font-0 = "JetBrainsMono Nerd Font:size=10;3"
font-1 = "JetBrainsMono Nerd Font:style=Bold:size=10;3"
font-2 = "Symbols Nerd Font:size=18;3,5"

modules-left = xworkspaces
modules-center = 
modules-right = left-arrow-3 podman left-arrow-2 network left-arrow-1 cpu memory temp left-arrow-0 audio brightness battery date

[module/xworkspaces]
type = internal/xworkspaces
label-active = %name%
label-active-foreground = ${sem_fg}
label-active-background = ${sem_surface}
label-active-padding = 1

label-occupied = %name%
label-occupied-foreground = ${sem_fg_dim}
label-occupied-padding = 1

label-empty = %name%
label-empty-foreground = ${sem_surface_hi}
label-empty-padding = 1

label-urgent = %name%
label-urgent-foreground = ${sem_danger}
label-urgent-padding = 1

[module/xwindow]
type = internal/xwindow
label = %title:0:60:...%
label-foreground = ${sem_fg}

[module/podman]
type = custom/script
exec = ~/.config/polybar/podman.sh
interval = 30
format-foreground = ${sem_fg}
format-background = ${sem_surface_xlight}
click-left = alacritty -e sh -c "podman ps -a; echo; echo 'Press Enter'; read"

[module/network]
type = custom/script
exec = ~/.config/polybar/net-toggle.sh
interval = 2
format-foreground = ${sem_fg}
format-background = ${sem_surface_hi}

[module/temp]
type = custom/script
exec = ~/.config/polybar/temperature.sh
interval = 2
format-foreground = ${sem_fg}
format-background = ${sem_surface}

[module/cpu]
type = internal/cpu
interval = 2
format = <label>
label = "  %percentage:2%% "
label-foreground = ${sem_fg}
label-background = ${sem_surface}

[module/memory]
type = internal/memory
interval = 2
format = <label>
label = "   %percentage_used:2%% "
label-foreground = ${sem_fg}
label-background = ${sem_surface}

[module/date]
type = internal/date
interval = 1
date = %H:%M:%S
format = <label>
label = " %date% "
label-foreground = ${sem_fg}
label-background = ${sem_bg}

[module/audio]
type = internal/pulseaudio
interval = 5
format-volume = <label-volume>
label-volume = " 󰕾 %percentage%% "
label-volume-foreground = ${sem_fg}
label-volume-background = ${sem_bg}

label-muted = " 󰖁 MUTED "
label-muted-foreground = ${sem_fg}
label-muted-background = ${sem_bg}

click-right = alacritty -e pulsemixer

[module/brightness]
type = custom/script
exec = ~/.config/polybar/brightness.sh
interval = 2
format-foreground = ${sem_fg}
format-background = ${sem_bg}

[module/battery]
type = internal/battery
full-at = 98
low-at = 20
battery = BAT0
adapter = AC
poll-interval = 5

format-charging = <animation-charging> <label-charging>
format-charging-foreground = ${sem_fg}
format-charging-background = ${sem_bg}

label-charging = "%percentage%% "
label-charging-foreground = ${sem_fg}
label-charging-background = ${sem_bg}

format-discharging = <ramp-capacity> <label-discharging>
format-discharging-foreground = ${sem_fg}
format-discharging-background = ${sem_bg}

label-discharging = "%percentage%% "
label-discharging-foreground = ${sem_fg}
label-discharging-background = ${sem_bg}

format-low = <label-low>
label-low = " 󰂎 %percentage%% "
label-low-foreground = ${sem_danger}
label-low-background = ${sem_bg}

label-full = " 󱊣 100% "
label-full-foreground = ${sem_fg}
label-full-background = ${sem_bg}

ramp-capacity-0 = " 󰂎 "
ramp-capacity-1 = " 󱊡 "
ramp-capacity-2 = " 󱊢 "
ramp-capacity-3 = " 󱊣 "

animation-charging-0 = " 󰢟 " 
animation-charging-1 = " 󱊤 "
animation-charging-2 = " 󱊥 "
animation-charging-3 = " 󱊦 "
animation-charging-foreground = ${sem_fg}
animation-charging-framerate = 750

[module/left-arrow-0]
type = custom/text
content = "%{T3}%{T-}"
content-foreground = ${sem_bg}
content-background = ${sem_surface}

[module/left-arrow-1]
type = custom/text
content = "%{T3}%{T-}"
content-foreground = ${sem_surface}
content-background = ${sem_surface_hi}

[module/left-arrow-2]
type = custom/text
content = "%{T3}%{T-}"
content-foreground = ${sem_surface_hi}
content-background = ${sem_surface_xlight}

[module/left-arrow-3]
type = custom/text
content = "%{T3}%{T-}"
content-foreground = ${sem_surface_xlight}
content-background = ${#00000000}
