# === Foregrounds ===
export fg='#c8d5c0'
export fg_dim='#7a8a78'
export fg_subtle='#9ba89b'

# === ANSI normal ===
export black='#0a120e'
export red='#8b1e1e'
export green='#2ea043'
export yellow='#b8860b'
export blue='#4a6f8a'
export magenta='#8b5a6a'
export cyan='#5e8a7a'
export white='#c8d5c0'

# === ANSI bright ===
export bright_black='#3a4a40'
export bright_red='#c83232'
export bright_green='#5a8a6b'
export bright_yellow='#d4a52a'
export bright_blue='#6a8fa8'
