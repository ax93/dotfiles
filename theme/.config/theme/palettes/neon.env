# neon palette
# run ~/.config/theme/build.sh

# === UI surfaces ===
export bg='#0a0a18'
export surface='#16142a'
export surface_hi='#241f3d'

# === Foregrounds ===
export fg='#d8d4f0'
export fg_dim='#7a7898'
export fg_subtle='#a8a4c8'

# === ANSI normal ===
export black='#0a0a18'
export red='#ff2d6f'
export green='#39ff7a'
export yellow='#ffcc00'
export blue='#00b3ff'
export magenta='#c77dff'
export cyan='#00ffd5'
export white='#d8d4f0'

# === ANSI bright ===
export bright_black='#3a3258'
export bright_red='#ff5c8a'
export bright_green='#7eff9e'
export bright_yellow='#ffe14d'
export bright_blue='#5ccfff'
export bright_magenta='#daa6ff'
export bright_cyan='#5cffe1'
export bright_white='#e8e4ff'

# === Raw (no #) ===
export bg_raw='0a0a18'
export surface_raw='16142a'
export surface_hi_raw='241f3d'
export fg_raw='d8d4f0'
export red_raw='ff2d6f'
export green_raw='39ff7a'
export bright_red_raw='ff5c8a'
export bright_green_raw='7eff9e'

# === Role overrides ===
export sem_accent="$magenta"
export sem_accent_dim="$bright_magenta"
