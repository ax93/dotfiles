# semantic roles
# sourced after palette.env in build.sh
# change palette.env to swap colors; this file maps roles to palette names

# === UI ===
export sem_bg="$bg"
export sem_surface="$surface"
export sem_surface_hi="$surface_hi"
export sem_fg="$fg"
export sem_fg_dim="$fg_dim"
export sem_fg_subtle="$fg_subtle"

# === Accent (focus, selected, brand) ===
#export sem_accent="$green"
#export sem_accent_dim="$bright_green"

# === State ===
export sem_danger="$red"
export sem_danger_hi="$bright_red"
export sem_warning="$yellow"
export sem_info="$cyan"

# === ANSI passthrough (for terminal color tables) ===
export sem_black="$black"
export sem_red="$red"
export sem_green="$green"
export sem_yellow="$yellow"
export sem_blue="$blue"
export sem_magenta="$magenta"
export sem_cyan="$cyan"
export sem_white="$white"

export sem_bright_black="$bright_black"
export sem_bright_red="$bright_red"
export sem_bright_green="$bright_green"
export sem_bright_yellow="$bright_yellow"
export sem_bright_blue="$bright_blue"
export sem_bright_magenta="$bright_magenta"
export sem_bright_cyan="$bright_cyan"
export sem_bright_white="$bright_white"

# === Raw passthrough ===
export sem_bg_raw="$bg_raw"
export sem_surface_raw="$surface_raw"
export sem_surface_hi_raw="$surface_hi_raw"
export sem_fg_raw="$fg_raw"
export sem_accent_raw="$green_raw"
export sem_accent_dim_raw="$bright_green_raw"
export sem_danger_raw="$red_raw"
export sem_danger_hi_raw="$bright_red_raw"
