[window]
padding = { x = 10, y = 10 }
opacity = 0.92
dynamic_padding = true

[font]
normal = { family = "JetBrainsMono Nerd Font", style = "Regular" }
size = 11.0

[colors.primary]
background = "${bg}"
foreground = "${fg}"
dim_foreground = "${fg_dim}"

[colors.cursor]
text = "${bg}"
cursor = "${green}"

[colors.selection]
text = "${fg}"
background = "${surface_hi}"

[colors.normal]
black   = "${surface}"
red     = "${blood}"
green   = "${green_dim}"
yellow  = "${amber}"
blue    = "${mist}"
magenta = "${green_deep}"
cyan    = "${mist}"
white   = "${bone}"

[colors.bright]
black   = "${surface_hi}"
red     = "${blood_bright}"
green   = "${green}"
yellow  = "${amber}"
blue    = "${mist}"
magenta = "${green_dim}"
cyan    = "${bone}"
white   = "${fg}"